<!--
  Adaptive icon foreground — 108 × 108 dp canvas.
  Safe zone: center 72 dp circle (offset 18 dp each side).
  Bus is drawn in the 68 dp safe area (20 dp offset) in white.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Original bus path is on 24×24 viewport.
      Scaled ×2.8 and translated to center it on 108×108:
        offset = (108 - 24*2.8) / 2 = (108 - 67.2) / 2 ≈ 20.4
